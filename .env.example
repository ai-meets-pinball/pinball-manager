# Kopiere diese Datei zu .env.local und fülle die Werte aus.

# Datenbank (Supabase Postgres) — für serverlose Umgebungen die Pooler-URL verwenden.
DATABASE_URL="postgresql://postgres:<passwort>@<host>:6543/postgres?sslmode=require"

# Better Auth
# Secret erzeugen mit: openssl rand -base64 32
BETTER_AUTH_SECRET="<zufaelliges-secret>"
BETTER_AUTH_URL="http://localhost:3000"

# E2E-Tests: EIGENE Datenbank, niemals die produktive. Die Suite legt Konten,
# Clubs, Maschinen und Freigaben an und löscht sie wieder.
# Einmalig einrichten:
#   1. zweites Supabase-Projekt (oder zweite DB) anlegen
#   2. Schema einspielen:  DATABASE_URL="$E2E_DATABASE_URL" npm run db:migrate
#   3. Browser holen:      npm run e2e:install
#   4. Tests starten:      npm run e2e
# Zeigt E2E_DATABASE_URL auf dieselbe DB wie POSTGRES_URL, brechen die Tests ab.
E2E_DATABASE_URL=""
# Port des Test-Servers (Standard 3101, damit `npm run dev` auf 3100 weiterläuft)
E2E_PORT="3101"

# Super-Admins (Bootstrap): Komma-getrennte E-Mail-Liste. Diese Konten werden beim
# nächsten Login automatisch zu Super-Admins hochgestuft; weitere lassen sich danach
# unter /admin ernennen. Leer lassen = kein automatischer Super-Admin.
SUPER_ADMIN_EMAILS=""

# Supabase Storage (nur Storage — nicht Auth, nicht Daten)
NEXT_PUBLIC_SUPABASE_URL="https://<projekt>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Name des Storage-Buckets für Maschinenfotos
NEXT_PUBLIC_SUPABASE_BUCKET="machine-photos"

# Open Pinball Database (OPDB) — Token unter https://opdb.org/account erzeugen.
# Wird serverseitig verwendet, um Maschinendaten zu suchen und zu übernehmen.
OPDB_API_KEY="<opdb-api-token>"

# Resend — E-Mail-Versand (z. B. „Passwort vergessen"). Key: https://resend.com/api-keys
RESEND_API_KEY="<resend-api-key>"
# Absenderadresse. Für Tests geht "onboarding@resend.dev"; sonst eine verifizierte Domain.
EMAIL_FROM="Pinball Manager <onboarding@resend.dev>"

# Anthropic (Claude) — Fakten-Extraktion aus hochgeladenen Handbüchern (Phase 2).
# Key: https://console.anthropic.com/settings/keys . Das PDF wird nie gespeichert,
# nur die extrahierten Faktentabellen. Modell optional überschreibbar.
ANTHROPIC_API_KEY="<anthropic-api-key>"
ANTHROPIC_MODEL="claude-sonnet-5"
# Optional: günstiges Modell für die "Claude günstig (Auto)"-Auswahl. Auto nimmt
# zuerst dieses Modell und schaltet nur bei leerem Ergebnis auf ANTHROPIC_MODEL
# (Sonnet) hoch. Beide laufen über denselben ANTHROPIC_API_KEY.
ANTHROPIC_HAIKU_MODEL="claude-haiku-4-5"

# KI-Anbieter: "anthropic" (Standard, Cloud/Vercel) oder "ollama" (LOKAL/self-hosted).
# Der Ollama-Pfad verarbeitet Handbuch, Guide und Wartungs-Import komplett lokal —
# ideal für Datenschutz. ACHTUNG: localhost:11434 ist von Vercel NICHT erreichbar,
# also nur für lokale/self-hosted Läufe. Der Guide entsteht dann OHNE Websuche.
AI_PROVIDER="anthropic"
# Nur relevant für AI_PROVIDER="ollama":
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma3:12b"         # Text-Modell (digitale PDFs, Guide, Import). ≥12B empfohlen.
OLLAMA_VISION_MODEL="gemma3:12b"  # multimodal, für gescannte/Bild-PDFs (Fallback: OLLAMA_MODEL)
LOCAL_VISION_MAX_PAGES="400"      # Obergrenze Seiten beim Vision-Pfad (gescannte PDFs)
LOCAL_VISION_BATCH_SIZE="6"       # Seiten je Modell-Aufruf; große gescannte Manuals werden häppchenweise verarbeitet
LOCAL_RENDER_SCALE="2"            # Renderauflösung als Scale-Faktor (~144 dpi bei 2)

# Wartungs-Reminder (Cron): Secret für die tägliche Route
# /api/cron/maintenance-reminders (siehe vercel.json). Vercel Cron sendet es als
# „Authorization: Bearer <CRON_SECRET>". Beliebiger Zufallswert; leer = Route 401.
CRON_SECRET="<zufaelliges-secret>"
